# ========== 服务端配置 ==========
PORT=3000

# JWT 密钥（上线请务必修改为随机长字符串）
JWT_SECRET=change_me_to_a_long_random_string_please
JWT_EXPIRES_IN=7d

# 管理员初始账号（仅首次启动未建用户时生效）
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin123

# 微信小程序（用于 wx.login code2Session 换 openid）
# 申请路径：https://mp.weixin.qq.com/  → 开发 → 开发管理 → 开发设置
WX_APPID=your_wx_appid
WX_SECRET=your_wx_secret

# 备份策略
BACKUP_CRON=0 2 * * *
BACKUP_KEEP=30

# MCP Server API Key（AI Agent 接入鉴权）
# 不配则每次启动自动生成并打印到日志，建议固定一个值
MCP_API_KEY=change_me_to_a_random_string
