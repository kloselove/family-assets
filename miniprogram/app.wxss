page { background: #f5f5f5; font-size: 28rpx; color: #333; }
.btn-primary { background: #667eea; color: #fff; }
.btn-danger { background: #dc3545; color: #fff; }
.btn-secondary { background: #888; color: #fff; }
button { border-radius: 8rpx; }
.input { background: #fff; padding: 20rpx 24rpx; border-radius: 8rpx; margin-bottom: 16rpx; font-size: 28rpx; }
.label { color: #666; font-size: 24rpx; margin-bottom: 8rpx; }
.card { background: #fff; padding: 24rpx; border-radius: 12rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.04); }
.row { display: flex; align-items: center; }
.flex1 { flex: 1; }
.muted { color: #999; font-size: 24rpx; }
.tag { display: inline-block; padding: 2rpx 16rpx; border-radius: 16rpx; font-size: 22rpx; background: #e9f3ff; color: #1976d2; margin-right: 10rpx; }
.tag.warn { background: #fff4d6; color: #b48a00; }
.tag.danger { background: #ffe2e2; color: #c0392b; }
.empty { text-align: center; color: #999; padding: 80rpx 0; }
.fab {
    position: fixed; right: 40rpx; bottom: 60rpx;
    width: 110rpx; height: 110rpx; border-radius: 55rpx;
    background: #667eea; color: #fff; font-size: 60rpx;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8rpx 20rpx rgba(102,126,234,.5);
}
