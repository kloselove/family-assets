.page { padding: 20rpx; padding-bottom: 200rpx; }
.stat-row { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.stat { flex: 1; background: #fff; border-radius: 12rpx; padding: 24rpx; text-align: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.04); }
.stat .num { font-size: 40rpx; font-weight: 700; color: #667eea; }
.stat.warn .num { color: #ff8c00; }
.stat.danger .num { color: #dc3545; }
.stat .lab { color: #999; font-size: 22rpx; margin-top: 6rpx; }
.search-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.search { flex: 1; background: #fff; padding: 16rpx 20rpx; border-radius: 8rpx; }
.picker { background: #fff; padding: 16rpx 20rpx; border-radius: 8rpx; font-size: 26rpx; color: #555; }
.name { font-size: 30rpx; font-weight: 600; margin-bottom: 8rpx; }
.meta { font-size: 24rpx; margin-top: 4rpx; }
.actions { display: flex; flex-direction: column; gap: 12rpx; margin-left: 16rpx; }
.actions button { font-size: 22rpx; padding: 0 18rpx; }
