<view class="page">
    <view class="userhead">
        <view class="avatar">{{user.username}}</view>
        <view class="role">{{user.role === 'admin' ? '管理员' : '家庭成员'}}</view>
    </view>

    <view class="card menu" bindtap="changePwd">
        <text>🔑 修改密码</text><text class="arrow">›</text>
    </view>
    <view class="card menu" bindtap="bindWx">
        <text>🟢 绑定/重新绑定微信</text><text class="arrow">›</text>
    </view>
    <view class="card menu danger" bindtap="logout">
        <text>退出登录</text><text class="arrow">›</text>
    </view>
</view>
