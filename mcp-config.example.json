{
  "_说明": "以下两种模式二选一",

  "_HTTP模式（推荐，NAS 场景）": "AI 客户端直接通过 HTTP 连接 NAS 上的 MCP 端点",
  "mcpServers_http": {
    "family-assets": {
      "type": "streamableHttp",
      "url": "http://192.168.31.92:3000/mcp"
    }
  },

  "_SSH_stdio模式（备用）": "通过 SSH 隧道连接 NAS 容器内的 stdio MCP Server",
  "mcpServers_ssh": {
    "family-assets": {
      "command": "ssh",
      "args": ["你的NAS用户名@192.168.31.92", "docker exec -i family-assets node /app/mcp-server.js"]
    }
  }
}
